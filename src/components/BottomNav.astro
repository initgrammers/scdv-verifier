---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = Astro.url.pathname;

const tabs = [
  {
    href: `${base}/`,
    label: 'Verificar',
    match: `${base}/`,
    svg: `<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>`,
  },
  {
    href: `${base}/historial/`,
    label: 'Historial',
    match: `${base}/historial/`,
    svg: `<rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/>`,
  },
  {
    href: `${base}/como-verificar/`,
    label: 'Guía',
    match: `${base}/como-verificar/`,
    svg: `<circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>`,
  },
];
---

<nav class="fixed bottom-0 left-0 right-0 z-50 flex justify-center pb-safe-or-6 pt-2"
  style="background: linear-gradient(to top, rgb(10 10 15 / 0.98) 70%, transparent);">

  <div class="flex gap-1 px-2 py-2 rounded-full bg-card border border-white/[0.07] shadow-2xl">
    {tabs.map(tab => {
      const isActive = path === tab.match || path === tab.href;
      return (
        <a
          href={tab.href}
          class:list={[
            'flex flex-col items-center justify-center w-16 h-12 rounded-full transition-all duration-200 gap-0.5 no-underline',
            isActive ? 'bg-accent text-bg' : 'text-muted hover:text-white',
          ]}
        >
          <svg
            width="18" height="18" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round"
            set:html={tab.svg}
          />
          <span class="text-[10px] font-bold leading-none">{tab.label}</span>
        </a>
      );
    })}
  </div>
</nav>
