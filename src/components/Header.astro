---
// Static header shell — no props
import { APP_NAME } from '../config/constants';
---

<header
  class="sticky top-0 z-40 px-5 py-4 flex items-center justify-between backdrop-blur-xl bg-bg/85 border-b border-white/[0.06]"
>
  <!-- Logo pill -->
  <div
    class="flex items-center gap-2 px-4 py-2 rounded-full bg-card border border-white/[0.07]"
  >
    <span class="w-2 h-2 rounded-full bg-accent shadow-glow-accent"></span>
    <span class="text-sm font-extrabold tracking-tight text-white"
      >{APP_NAME}</span
    >
  </div>
</header>
