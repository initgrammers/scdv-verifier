---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'SCDV Verificador',
  description = 'Verificador de certificados digitales auténticos',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es" class="bg-bg">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#C8F135" />
    <meta name="description" content={description} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="manifest" href={`${base}manifest.json`} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-bg text-white font-sans min-h-screen flex flex-col">
    <slot />
    <script define:vars={{ base }}>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register(base + 'sw.js').catch(console.error);
        });
      }
    </script>
  </body>
</html>
