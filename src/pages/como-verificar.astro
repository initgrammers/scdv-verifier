---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import BottomNav from '../components/BottomNav.astro';
import { APP_NAME } from '../config/constants';
---

<BaseLayout title={`Cómo verificar - ${APP_NAME}`}>
  <Header />
  <main class="flex-1 pb-28">

    <!-- Page title -->
    <div style="padding: 24px 24px 20px;">
      <h1 style="font-size: 28px; font-weight: 800; color: #fff; line-height: 1.15; letter-spacing: -0.5px; margin: 0 0 6px;">
        Cómo verificar
      </h1>
      <p style="font-size: 14px; color: rgba(255,255,255,0.4); font-weight: 500; margin: 0;">
        Aprende a validar certificados digitales
      </p>
    </div>

    <!-- Steps -->
    <div style="padding: 0 20px; display: flex; flex-direction: column; gap: 10px;">

      <!-- Step 1 -->
      <div style="
        background: linear-gradient(145deg, rgba(255,255,255,0.055) 0%, rgba(255,255,255,0.025) 100%);
        border: 1px solid rgba(255,255,255,0.09);
        border-radius: 20px;
        padding: 18px;
        display: flex;
        align-items: flex-start;
        gap: 16px;
      ">
        <div style="
          width: 44px; height: 44px; flex-shrink: 0;
          border-radius: 14px;
          background: rgba(132,204,22,0.15);
          border: 1px solid rgba(132,204,22,0.25);
          display: flex; align-items: center; justify-content: center;
        ">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#84cc16" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
          </svg>
        </div>
        <div style="flex: 1; min-width: 0;">
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
            <span style="font-size: 10px; font-weight: 800; color: #84cc16; letter-spacing: 0.1em; text-transform: uppercase;">Paso 1</span>
          </div>
          <h2 style="font-size: 15px; font-weight: 800; color: #fff; margin: 0 0 6px; line-height: 1.3;">
            Escanea el código QR
          </h2>
          <p style="font-size: 13px; color: rgba(255,255,255,0.45); line-height: 1.65; margin: 0;">
            Apunta la cámara al código QR del certificado. El verificador detectará automáticamente el código.
          </p>
        </div>
      </div>

      <!-- Step 2 -->
      <div style="
        background: linear-gradient(145deg, rgba(255,255,255,0.055) 0%, rgba(255,255,255,0.025) 100%);
        border: 1px solid rgba(255,255,255,0.09);
        border-radius: 20px;
        padding: 18px;
        display: flex;
        align-items: flex-start;
        gap: 16px;
      ">
        <div style="
          width: 44px; height: 44px; flex-shrink: 0;
          border-radius: 14px;
          background: rgba(132,204,22,0.15);
          border: 1px solid rgba(132,204,22,0.25);
          display: flex; align-items: center; justify-content: center;
        ">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#84cc16" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
          </svg>
        </div>
        <div style="flex: 1; min-width: 0;">
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
            <span style="font-size: 10px; font-weight: 800; color: #84cc16; letter-spacing: 0.1em; text-transform: uppercase;">Paso 2 · Alternativo</span>
          </div>
          <h2 style="font-size: 15px; font-weight: 800; color: #fff; margin: 0 0 6px; line-height: 1.3;">
            Ingresa el código manualmente
          </h2>
          <p style="font-size: 13px; color: rgba(255,255,255,0.45); line-height: 1.65; margin: 0;">
            Si no puedes escanear, toca el botón "Manual" y pega el código del certificado.
          </p>
        </div>
      </div>

      <!-- Step 3 -->
      <div style="
        background: linear-gradient(145deg, rgba(255,255,255,0.055) 0%, rgba(255,255,255,0.025) 100%);
        border: 1px solid rgba(255,255,255,0.09);
        border-radius: 20px;
        padding: 18px;
        display: flex;
        align-items: flex-start;
        gap: 16px;
      ">
        <div style="
          width: 44px; height: 44px; flex-shrink: 0;
          border-radius: 14px;
          background: rgba(132,204,22,0.15);
          border: 1px solid rgba(132,204,22,0.25);
          display: flex; align-items: center; justify-content: center;
        ">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#84cc16" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <div style="flex: 1; min-width: 0;">
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
            <span style="font-size: 10px; font-weight: 800; color: #84cc16; letter-spacing: 0.1em; text-transform: uppercase;">Paso 3</span>
          </div>
          <h2 style="font-size: 15px; font-weight: 800; color: #fff; margin: 0 0 6px; line-height: 1.3;">
            Verificación automática
          </h2>
          <p style="font-size: 13px; color: rgba(255,255,255,0.45); line-height: 1.65; margin: 0;">
            La app verifica criptográficamente en 2 pasos: valida que el curso esté autorizado y que los datos no fueron alterados.
          </p>
        </div>
      </div>

      <!-- Step 4 -->
      <div style="
        background: linear-gradient(145deg, rgba(255,255,255,0.055) 0%, rgba(255,255,255,0.025) 100%);
        border: 1px solid rgba(255,255,255,0.09);
        border-radius: 20px;
        padding: 18px;
        display: flex;
        align-items: flex-start;
        gap: 16px;
      ">
        <div style="
          width: 44px; height: 44px; flex-shrink: 0;
          border-radius: 14px;
          background: rgba(132,204,22,0.15);
          border: 1px solid rgba(132,204,22,0.25);
          display: flex; align-items: center; justify-content: center;
        ">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#84cc16" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
        </div>
        <div style="flex: 1; min-width: 0;">
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
            <span style="font-size: 10px; font-weight: 800; color: #84cc16; letter-spacing: 0.1em; text-transform: uppercase;">Paso 4</span>
          </div>
          <h2 style="font-size: 15px; font-weight: 800; color: #fff; margin: 0 0 6px; line-height: 1.3;">
            Resultado instantáneo
          </h2>
          <p style="font-size: 13px; color: rgba(255,255,255,0.45); line-height: 1.65; margin: 0;">
            En segundos verás si el certificado es válido o inválido, junto con los datos del mismo.
          </p>
        </div>
      </div>

      <!-- What does this app verify? -->
      <div style="
        background: linear-gradient(145deg, rgba(132,204,22,0.07) 0%, rgba(132,204,22,0.02) 100%);
        border: 1px solid rgba(132,204,22,0.18);
        border-radius: 20px;
        padding: 18px;
        margin-top: 6px;
      ">
        <h3 style="font-size: 12px; font-weight: 800; color: #84cc16; letter-spacing: 0.08em; text-transform: uppercase; margin: 0 0 14px;">
          ¿Qué verifica esta app?
        </h3>
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 11px;">
          <li style="display: flex; align-items: flex-start; gap: 10px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#84cc16" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top: 1px;">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span style="font-size: 13px; color: rgba(255,255,255,0.55); line-height: 1.5;">
              Que la clave del curso fue firmada por la <strong style="color: rgba(255,255,255,0.8); font-weight: 700;">autoridad raíz</strong>
            </span>
          </li>
          <li style="display: flex; align-items: flex-start; gap: 10px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#84cc16" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top: 1px;">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span style="font-size: 13px; color: rgba(255,255,255,0.55); line-height: 1.5;">
              Que los datos del certificado <strong style="color: rgba(255,255,255,0.8); font-weight: 700;">no fueron modificados</strong>
            </span>
          </li>
          <li style="display: flex; align-items: flex-start; gap: 10px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#84cc16" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top: 1px;">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span style="font-size: 13px; color: rgba(255,255,255,0.55); line-height: 1.5;">
              Que la <strong style="color: rgba(255,255,255,0.8); font-weight: 700;">firma criptográfica</strong> es auténtica
            </span>
          </li>
        </ul>
      </div>

      <!-- Footer note -->
      <div style="text-align: center; padding: 12px 0 4px;">
        <p style="font-size: 11px; color: rgba(255,255,255,0.2); letter-spacing: 0.04em; margin: 0;">
          Funciona offline &nbsp;•&nbsp; Sin registro &nbsp;•&nbsp; Sin datos personales
        </p>
      </div>

    </div>
  </main>
  <BottomNav />
</BaseLayout>