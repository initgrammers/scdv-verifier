{
  "name": "scdv-verificador",
  "version": "1.0.0",
  "description": "Sistema de Certificados Digitales Verificables - Frontend Verificador",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync:agents": "cat AGENTS.md skills/*.md > .cursorrules && cp .cursorrules CLAUDE.md && cp .cursorrules .windsurfrules && cp .cursorrules .geminirules",
    "setup:agents": "bun run sync:agents"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.3",
    "@astrojs/tailwind": "^5.0.0",
    "@nanostores/react": "^1.1.0",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "@types/animejs": "^3.1.13",
    "@yudiel/react-qr-scanner": "^2.5.1",
    "animejs": "^4.3.6",
    "astro": "^6.1.7",
    "lucide-react": "^1.8.0",
    "nanostores": "^1.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/astro": "^1.2.0",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.0.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.8.0",
    "vite-plugin-mkcert": "^2.0.0",
    "vitest": "^2.1.0"
  }
}
